// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  //url = env("DATABASE_URL")
}

model model_training_plans{
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid //random uuid
  user_id String @db.Uuid
  plan_json Json 
  plan_text String
  version Int @default(1)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  @@index([user_id], map: "idx_training_plans_user_id")
}

model user_profiles {
  user_id String @id @db.Uuid
  goal String @db.VarChar (20)
  experience String @db.VarChar (20)
  daysPerWeek Int
  minutesPerDay Int
  split String @db.VarChar (20)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
}

model workout_sessions {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String   @db.Uuid
  plan_id      String   @db.Uuid
  day_label    String   @db.VarChar(50)
  focus        String   @db.VarChar(100)
  completed    Boolean  @default(false)
  notes        String?  @db.Text
  session_date DateTime @db.Date
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  exercises session_exercises[]

  @@index([user_id])
  @@index([user_id, session_date])
}

model session_exercises {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id     String  @db.Uuid
  exercise_name  String  @db.VarChar(200)
  exercise_order Int
  sets_data      Json
  skipped        Boolean @default(false)

  session workout_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
}
